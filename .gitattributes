# Normalisation des fins de ligne
* text=auto eol=lf

# Fichiers Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaires — pas de conversion
*.png binary
*.jpg binary
*.pdf binary
*.pbix binary
*.joblib binary
*.parquet binary
*.duckdb binary

# Notebooks : diffs lisibles, pas de fusion automatique
*.ipynb -merge
